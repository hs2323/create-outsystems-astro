{
  "name": "create-outsystems-astro",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "audit:bun": "bun audit",
    "audit:deno": "deno audit",
    "audit:npm": "better-npm-audit audit",
    "audit:pnpm": "pnpm audit",
    "audit:yarn": "yarn run improved-yarn-audit",
    "build": "astro build",
    "dev": "astro dev",
    "format": "prettier . --check",
    "format:write": "prettier  --write .",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "output": "astro build && ts-node ./output.ts",
    "output:bun": "astro build && bun run ./output.ts",
    "output:deno": "astro build && deno run -A ./output.ts",
    "postinstall": "patch-package",
    "preview": "astro preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:deno": "PW_DISABLE_TS_ESM=true deno run --allow-all npm:playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ui:deno": "PW_DISABLE_TS_ESM=true deno run --allow-all npm:playwright test --ui",
    "test:e2e:install": "playwright install --with-deps",
    "test:run": "vitest run",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@analogjs/astro-angular": "^2.3.0",
    "@angular/animations": "^21.1.6",
    "@angular/build": "^21.1.5",
    "@angular/common": "^21.1.6",
    "@angular/compiler": "^21.1.6",
    "@angular/compiler-cli": "^21.1.6",
    "@angular/core": "^21.1.6",
    "@angular/language-service": "^21.1.6",
    "@angular/platform-browser": "^21.1.6",
    "@angular/platform-server": "^21.1.6",
    "@astrojs/preact": "^4.1.3",
    "@astrojs/react": "^4.4.2",
    "@astrojs/svelte": "^7.2.5",
    "@astrojs/vue": "^5.1.4",
    "@nanostores/preact": "^1.0.0",
    "@nanostores/react": "^1.0.0",
    "@nanostores/vue": "^1.0.1",
    "astro": "^5.18.0",
    "nanostores": "^1.1.1",
    "preact": "^10.28.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rxjs": "^7.8.2",
    "svelte": "^5.53.6",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.0",
    "@analogjs/vitest-angular": "^2.3.0",
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/schematics": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/router": "^21.1.6",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.3",
    "@eslint/markdown": "^7.5.1",
    "@playwright/test": "1.57.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/angular": "^19.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-vue": "^6.0.4",
    "angular-eslint": "^21.2.0",
    "better-npm-audit": "^3.11.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-playwright": "^2.8.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-svelte": "^3.15.0",
    "eslint-plugin-testing-library": "^7.16.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "happy-dom": "^20.7.0",
    "improved-yarn-audit": "^3.0.4",
    "js-beautify": "^1.15.4",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte-eslint-parser": "^1.5.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0"
  }
}
