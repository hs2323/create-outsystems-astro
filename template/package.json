{
  "name": "create-outsystems-astro",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "audit:bun": "bun audit",
    "audit:deno": "deno audit",
    "audit:npm": "better-npm-audit audit",
    "audit:pnpm": "pnpm audit",
    "audit:yarn": "yarn run improved-yarn-audit",
    "build": "astro build",
    "dev": "astro dev",
    "format": "prettier . --check",
    "format:write": "prettier  --write .",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "output": "cross-env NODE_ENV=production astro build && ts-node ./output.ts",
    "output:bun": "cross-env NODE_ENV=production astro build && bun run ./output.ts",
    "output:deno": "cross-env NODE_ENV=production astro build && deno run -A ./output.ts",
    "postinstall": "patch-package",
    "preview": "astro preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:deno": "cross-env PW_DISABLE_TS_ESM=true deno run --allow-all npm:playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ui:deno": "cross-env PW_DISABLE_TS_ESM=true deno run --allow-all npm:playwright test --ui",
    "test:e2e:install": "playwright install --with-deps",
    "test:run": "vitest run",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@analogjs/astro-angular": "^2.5.0",
    "@angular/animations": "^21.2.11",
    "@angular/common": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/platform-server": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@astrojs/preact": "^5.1.2",
    "@astrojs/react": "^5.0.4",
    "@astrojs/solid-js": "^6.0.1",
    "@astrojs/svelte": "^8.1.0",
    "@astrojs/vue": "^6.0.1",
    "@nanostores/preact": "^1.1.0",
    "@nanostores/react": "^1.1.0",
    "@nanostores/solid": "^1.1.1",
    "@nanostores/vue": "^1.1.0",
    "astro": "^6.2.2",
    "nanostores": "^1.3.0",
    "preact": "^10.29.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rxjs": "^7.8.2",
    "solid-js": "^1.9.12",
    "svelte": "^5.55.5",
    "tslib": "^2.8.1",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.0",
    "@analogjs/vitest-angular": "^2.5.0",
    "@angular-devkit/architect": "^0.2102.9",
    "@angular-devkit/schematics": "^21.2.9",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler": "^21.2.11",
    "@angular/compiler-cli": "^21.2.11",
    "@angular/language-service": "^21.2.11",
    "@babel/core": "^7.29.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@eslint/markdown": "^8.0.1",
    "@oxc-project/runtime": "^0.128.0",
    "@playwright/test": "1.59.1",
    "@preact/preset-vite": "^2.10.5",
    "@solidjs/testing-library": "^0.8.10",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/angular": "^19.1.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "angular-eslint": "^21.3.1",
    "better-npm-audit": "^3.11.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-preact": "^2.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-svelte": "^3.17.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "improved-yarn-audit": "^3.0.4",
    "js-beautify": "^1.15.4",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-solidity": "^2.3.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte-eslint-parser": "^1.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite-plugin-solid": "^2.11.11",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0"
  }
}
