{
  "name": "islands-integrations",
  "version": "0.11.0",
  "description": "Integrations for OutSystems Astro Islands",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "audit:bun": "bun audit",
    "audit:deno": "deno audit",
    "audit:npm": "better-npm-audit audit",
    "audit:pnpm": "pnpm audit",
    "audit:yarn": "yarn npm audit",
    "build": "tsc",
    "format": "prettier . --check",
    "format:write": "prettier  --write .",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepublishOnly": "tsc",
    "process": "tsc && mv dist ../template/.integrations && cp package.json ../template/.integrations/package.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "astro": "^6.4.4",
    "twig": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.2",
    "@types/twig": "^1.12.17",
    "better-npm-audit": "^3.11.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "resolutions": {
    "esbuild": "^0.28.1"
  }
}
